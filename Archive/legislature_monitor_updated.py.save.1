def get_or_create_folder_in_user_drive(service, folder_name, owner_email):
    """Get or create a folder and share it with the owner, then return the folder ID."""
    try:
        if not owner_email:
            logger.warning("OWNER_EMAIL not set, creating folder in service account drive")
            return get_or_create_folder_in_service_drive(service, folder_name), service
        
        folder_id = get_or_create_folder_in_service_drive(service, folder_name)
        if not folder_id:
            return None, service
        
        try:
            permission = {
                'type': 'user',
                'role': 'owner',
                'emailAddress': owner_email
            }
            
            service.permissions().create(
                fileId=folder_id,
                body=permission,
                fields='id',
                transferOwnership=True,
                sendNotificationEmail=False
            ).execute()
            
            logger.info(f"Transferred folder ownership to {owner_email}")
            return folder_id, service
            
        except Exception as e:
            logger.warning(f"Could not transfer folder ownership (expected for Gmail accounts): {e}")
            try:
                permission = {
                    'type': 'user',
                    'role': 'writer',
                    'emailAddress': owner_email
                }
                
                service.permissions().create(
                    fileId=folder_id,
                    body=permission,
                    fields='id',
                    sendNotificationEmail=False
                ).execute()
                
                logger.info(f"Shared folder with {owner_email} (write access)")
                return folder_id, service
                
            except Exception as e2:
                logger.error(f"Error sharing folder: {e2}")
                return folder_id, service
        
    except Exception as e:
        logger.error(f"Error getting or creating folder: {e}")
        return None, service


def get_or_create_folder_in_service_drive(service, folder_name):
    """Get or create a folder in the service account's drive."""
    try:
        results = service.files().list(
            q=f"name='{folder_name}' and mimeType='application/vnd.google-apps.folder' and trashed=false",
            spaces='drive',
            fields='files(id, name)'
        ).execute()
        
        items = results.get('files', [])
        
        if items:
            folder_id = items[0]['id']
            logger.info(f"Found existing folder: {folder_name} (ID: {folder_id})")
            return folder_id
        else:
            folder_metadata = {
                'name': folder_name,
                'mimeType': 'application/vnd.google-apps.folder'
            }
            
            folder = service.files().create(
                body=folder_metadata,
                fields='id'
            ).execute()
            
            folder_id = folder.get('id')
            logger.info(f"Created new folder: {folder_name} (ID: {folder_id})")
            return folder_id
            
    except Exception as e:
        logger.error(f"Error getting or creating folder in service drive: {e}")
        return None


def create_document_and_transfer_ownership(docs_service, drive_service, doc_title, folder_id, owner_email):
    """Create a document and attempt to transfer ownership, with Gmail-specific handling."""
    try:
        document = docs_service.documents().create(
            body={'title': doc_title}
        ).execute()
        doc_id = document.get('documentId')
        
        try:
            file = drive_service.files().get(
                fileId=doc_id,
                fields='parents'
            ).execute()
            previous_parents = ",".join(file.get('parents', []))
            
            drive_service.files().update(
                fileId=doc_id,
                addParents=folder_id,
                removeParents=previous_parents,
                fields='id, parents'
            ).execute()
            
            logger.info(f"Moved document to folder: {GOOGLE_DOCS_FOLDER_NAME}")
            
        except Exception as e:
            logger.error(f"Error moving document to folder: {e}")
        
        if owner_email:
            try:
                permission = {
                    'type': 'user',
                    'role': 'owner',
                    'emailAddress': owner_email
                }
                
                drive_service.permissions().create(
                    fileId=doc_id,
                    body=permission,
                    fields='id',
                    transferOwnership=True,
                    sendNotificationEmail=False
                ).execute()
                
                logger.info(f"Transferred document ownership to {owner_email}")
                
            except Exception as e:
                logger.warning(f"Could not transfer document ownership (expected for Gmail accounts): {e}")
                try:
                    permission = {
                        'type': 'user',
                        'role': 'writer',
                        'emailAddress': owner_email
                    }
                    
                    drive_service.permissions().create(
                        fileId=doc_id,
                        body=permission,
                        fields='id',
                        sendNotificationEmail=False
                    ).execute()
                    
                    logger.info(f"Shared document with {owner_email} (write access)")
                    
                except Exception as e2:
                    logger.error(f"Error sharing document with owner: {e2}")
        
        return doc_id
        
    except Exception as e:
        logger.error(f"Error creating document: {e}")
        return None


def create_google_doc(transcript_data, title, entry_url):
    """Create a Google Doc with the transcription and organize it properly."""
    try:
        creds = get_google_credentials()
        if not creds:
            logger.error("Failed to get Google credentials")
            return None
            
        docs_service = build('docs', 'v1', credentials=creds)
        drive_service = build('drive', 'v3', credentials=creds)
        
        folder_id, _ = get_or_create_folder_in_user_drive(drive_service, GOOGLE_DOCS_FOLDER_NAME, OWNER_EMAIL)
        
        if not folder_id:
            logger.error("Failed to get or create folder")
            return None
        
        date_prefix = datetime.datetime.now().strftime("%Y-%m-%d")
        doc_title = f"{date_prefix} - {title}"
        
        doc_id = create_document_and_transfer_ownership(
            docs_service, drive_service, doc_title, folder_id, OWNER_EMAIL
        )
        
        if not doc_id:
            logger.error("Failed to create document")
            return None
        
        logger.info(f"Created Google Doc with title: {doc_title}")
        
        content = []
        
        content.append({
            'insertText': {
                'text': f"Transcription of: {title}\n",
                'endOfSegmentLocation': {}
            }
        })
        
        content.append({
            'insertText': {
                'text': f"Source URL: {entry_url}\n",
                'endOfSegmentLocation': {}
            }
        })
        
        content.append({
            'insertText': {
                'text': f"Transcribed on: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n",
                'endOfSegmentLocation': {}
            }
        })
        
        formatted_transcript = format_transcript_for_google_docs(transcript_data)
        
        content.append({
            'insertText': {
                'text': formatted_transcript,
                'endOfSegmentLocation': {}
            }
        })
        
        docs_service.documents().batchUpdate(
            documentId=doc_id,
            body={'requests': content}
        ).execute()
        
        if SHARE_EMAIL and SHARE_EMAIL != OWNER_EMAIL:
            try:
                permission = {
                    'type': 'user',
                    'role': 'writer',
                    'emailAddress': SHARE_EMAIL
                }
                
                drive_service.permissions().create(
                    fileId=doc_id,
                    body=permission,
                    fields='id',
                    sendNotificationEmail=True
                ).execute()
                
                logger.info(f"Shared document with {SHARE_EMAIL}")
            except Exception as e:
                logger.error(f"Error sharing document: {e}")
        
        doc_url = f"https://docs.google.com/document/d/{doc_id}/edit"
        
        return doc_url
    
    except Exception as e:
        logger.error(f"Error creating Google Doc: {e}")
        return None


def get_current_entries():
    """Fetch and parse the current entries from the website using proxy rotation."""
    try:
        # Use proxy-enabled request
        response = make_request_with_proxy(URL)
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        entries = []
        
        for entry_element in soup.select('table'):
            entry_text = entry_element.get_text().strip()
            
            parent_a = entry_element.find_parent('a')
            entry_link = None
            if parent_a and 'href' in parent_a.attrs:
                entry_link = parent_a['href']
                if entry_link and not entry_link.startswith('http'):
                    base_url = '/'.join(URL.split('/')[:3])
                    entry_link = f"{base_url}{entry_link if entry_link.startswith('/') else '/' + entry_link}"
            
            if entry_text:
                entries.append({
                    'text': entry_text,
                    'link': entry_link,
                    'timestamp': datetime.datetime.now().isoformat()
                })
        
        return entries
    
    except Exception as e:
        logger.error(f"Error fetching entries: {e}")
        return []


