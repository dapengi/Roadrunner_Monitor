        video_filename = os.path.join(
            DOWNLOAD_DIR, 
            f"video_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.mp4"
        )
        
        # Use yt-dlp with fallback strategies
        return download_with_ytdlp_fallback(hls_url, video_filename)
    
    except Exception as e:
        logger.error(f"Error in video download process: {e}")
        return None


def extract_audio_from_video(video_path):
    """Extract audio from video file using yt-dlp (more reliable than ffmpeg)."""
    try:
        if not os.path.exists(video_path):
            logger.error(f"Video file not found: {video_path}")
            return None
        
        audio_path = video_path.replace('.mp4', '.mp3')
        
        logger.info(f"Extracting audio from {video_path} to {audio_path}")
        
        # Use yt-dlp to extract audio
        ydl_opts = {
            'format': 'bestaudio/best',
            'outtmpl': audio_path.replace('.mp3', '.%(ext)s'),
            'postprocessors': [{
                'key': 'FFmpegExtractAudio',
                'preferredcodec': 'mp3',
                'preferredquality': '192',
            }],
            'ignoreerrors': False,
        }
        
        try:
            with yt_dlp.YoutubeDL(ydl_opts) as ydl:
                ydl.download([video_path])
            
            if os.path.exists(audio_path):
                logger.info(f"Audio extracted successfully to {audio_path}")
                return audio_path
            else:
                logger.error("Audio extraction failed - file not created")
                return None
                
        except Exception as e:
            logger.warning(f"yt-dlp audio extraction failed: {e}")
            # Fallback to ffmpeg if available
            return extract_audio_with_ffmpeg_fallback(video_path)
    
    except Exception as e:
        logger.error(f"Error extracting audio: {e}")
        return None


def extract_audio_with_ffmpeg_fallback(video_path):
    """Fallback audio extraction using ffmpeg."""
    try:
        audio_path = video_path.replace('.mp4', '.mp3')
        
        logger.info(f"Trying ffmpeg fallback for audio extraction...")
        
        # Check if ffmpeg is available
        try:
            subprocess.run(['ffmpeg', '-version'], check=True, capture_output=True)
        except (subprocess.SubprocessError, FileNotFoundError):
            logger.error("ffmpeg not found. Cannot extract audio.")
            return None
        
        result = subprocess.run([
            'ffmpeg', '-i', video_path, '-q:a', '0', '-map', 'a', audio_path
        ], check=True, capture_output=True)
        
        if os.path.exists(audio_path):
            logger.info(f"Audio extracted successfully with ffmpeg to {audio_path}")
            return audio_path
        else:
            logger.error("ffmpeg audio extraction failed")
            return None
    
    except Exception as e:
        logger.error(f"ffmpeg fallback failed: {e}")
        return None


def transcribe_with_assemblyai(audio_path):
    """Transcribe audio using AssemblyAI API."""
    if not ASSEMBLYAI_API_KEY:
        logger.error("AssemblyAI API key not found in environment variables")
        return None
    
    try:
        headers = {
            "authorization": ASSEMBLYAI_API_KEY,
            "content-type": "application/json"
        }
        
        logger.info(f"Uploading audio file to AssemblyAI: {audio_path}")
        
        with open(audio_path, "rb") as f:
            response = requests.post(
                f"{ASSEMBLYAI_BASE_URL}/upload",
                headers=headers,
                data=f
            )
            response.raise_for_status()
        
        upload_url = response.json()["upload_url"]
        logger.info(f"Audio uploaded successfully. URL: {upload_url}")
        
        logger.info("Submitting transcription request")
        response = requests.post(
            f"{ASSEMBLYAI_BASE_URL}/transcript",
            headers=headers,
            json={
                "audio_url": upload_url,
                "speaker_labels": True,
                "punctuate": True,
                "format_text": True
            }
        )
        response.raise_for_status()
        
        transcript_id = response.json()["id"]
        logger.info(f"Transcription request submitted. ID: {transcript_id}")
        
        logger.info("Waiting for transcription to complete...")
        
        while True:
            response = requests.get(
                f"{ASSEMBLYAI_BASE_URL}/transcript/{transcript_id}",
                headers=headers
            )
            response.raise_for_status()
            
            status = response.json()["status"]
            
            if status == "completed":
                logger.info("Transcription completed successfully")
                return response.json()
            elif status == "error":
                logger.error(f"Transcription failed: {response.json().get('error')}")
                return None
            
            logger.info(f"Transcription status: {status}. Waiting...")
            time.sleep(30)  # Poll every 30 seconds
    
    except Exception as e:
        logger.error(f"Error in transcription process: {e}")
        return None


def format_transcript_for_google_docs(transcript_data):
    """Format the transcript data for Google Docs."""
    if not transcript_data or "words" not in transcript_data:
        return "Transcription failed or no words found."
    
    formatted_text = ""
    current_speaker = None
    current_paragraph = ""
    
    for word in transcript_data["words"]:
        speaker = word.get("speaker")
        
        if speaker != current_speaker:
            if current_paragraph:
                formatted_text += current_paragraph + "\n\n"
                current_paragraph = ""
            
            current_speaker = speaker
            if speaker is not None:
                current_paragraph = f"Speaker {speaker}: {word['text']} "
            else:
                current_paragraph = f"{word['text']} "
        else:
            current_paragraph += f"{word['text']} "
    
    if current_paragraph:
        formatted_text += current_paragraph
    
    if not formatted_text.strip():
        formatted_text = transcript_data.get("text", "No transcription text available.")
    
    metadata = f"""
Transcription Metadata:
- Transcribed by LWE.Vote
- Transcribed at: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}
- Audio duration: {transcript_data.get('audio_duration', 'Unknown')} seconds
- Confidence score: {transcript_data.get('confidence', 'Unknown')}
"""
    
    return f"{metadata}\n\n{formatted_text}"


def process_new_entry(entry):
    """Process a new entry: download video, transcribe, and save to Google Docs."""
    try:
        if not entry.get('link'):
            logger.error("Entry has no link, cannot process")
            return None
        
        video_path = download_video(entry['link'])
        if not video_path:
            logger.error("Failed to download video")
            return None
        
        audio_path = extract_audio_from_video(video_path)
        if not audio_path:
            logger.error("Failed to extract audio")
            return None
        
        transcript_data = transcribe_with_assemblyai(audio_path)
        if not transcript_data:
            logger.error("Failed to transcribe audio")
            return None
        
        formatted_transcript = format_transcript_for_google_docs(transcript_data)
        
        title_text = entry['text']
        title = re.sub(r'\s+', ' ', title_text)[:100] + " - Transcript"
        
        doc_url = create_google_doc(transcript_data, title, entry['link'])
        
        entry['transcription'] = {
            'video_path': video_path,
            'audio_path': audio_path,
            'google_doc_url': doc_url,
            'processed_at': datetime.datetime.now().isoformat()
        }
        
        write_processed_entry(entry)
        
        return doc_url
    
    except Exception as e:
        logger.error(f"Error processing entry: {e}")
        return None


def test_proxy_connectivity():
    """Test if proxies are working correctly."""
    logger.info("Testing proxy connectivity...")
    
    test_url = "http://httpbin.org/ip"  # Simple IP echo service
    
    for i in range(min(5, len(proxy_list))):  # Test first 5 proxies
        proxy = proxy_list[i]
        proxy_dict = get_proxy_dict(proxy)
        
        try:
            response = requests.get(test_url, proxies=proxy_dict, timeout=10)
            response.raise_for_status()
            ip_data = response.json()
            logger.info(f"Proxy {proxy['ip']}:{proxy['port']} - Working (IP: {ip_data.get('origin', 'unknown')})")
        except Exception as e:
            logger.warning(f"Proxy {proxy['ip']}:{proxy['port']} - Failed: {e}")
    
    # Test without proxy
    try:
        response = requests.get(test_url, timeout=10)
        response.raise_for_status()
        ip_data = response.json()
        logger.info(f"Direct connection - Working (IP: {ip_data.get('origin', 'unknown')})")
    except Exception as e:
        logger.warning(f"Direct connection - Failed: {e}")


def check_for_new_entries():
    """Check for new entries and process them if found."""
    # Check if we need to update proxy list
    if should_update_proxy_list():
        logger.info("Updating proxy list...")
        download_proxy_list()
        load_proxy_list()
    
    # Check if we need to run daily cleanup
    if should_run_daily_cleanup():
        logger.info("Running daily cleanup of downloads directory...")
        cleanup_downloads_directory()
    
    logger.info(f"Checking for new entries at {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}")
    
    current_entries = get_current_entries()
    stored_entries = read_stored_entries()
    
    stored_texts = [entry['text'] for entry in stored_entries]
    new_entries = [entry for entry in current_entries if entry['text'] not in stored_texts]
    
    if new_entries:
        logger.info(f"Found {len(new_entries)} new entries!")
        
        transcription_urls = []
        for entry in new_entries:
            logger.info(f"Processing entry: {entry['text'][:50]}...")
            doc_url = process_new_entry(entry)
            transcription_urls.append(doc_url)
        
        send_notification(new_entries, transcription_urls)
        write_entries(current_entries)
    else:
        logger.info("No new entries found")


def main():
    """Main function to schedule and run the monitoring."""
    logger.info("Starting Legislature page monitoring with yt-dlp, AssemblyAI, Google Docs, and Proxy integration...")
    
    # Initialize proxy system
    logger.info("Initializing proxy system...")
    if not load_proxy_list():
        logger.warning("Failed to load proxy list. Script will attempt to run without proxies.")
    else:
        logger.info(f"Proxy system initialized with {len(proxy_list)} proxies")
        # Test proxy connectivity
        test_proxy_connectivity()
    
    # Check for required dependencies
    try:
        import yt_dlp
        logger.info("yt-dlp is available")
    except ImportError:
        logger.error("yt-dlp not found. Please install with: pip install yt-dlp")
        return
    
    # Check for ffmpeg (optional, for fallback)
    try:
        subprocess.run(['ffmpeg', '-version'], check=True, capture_output=True)
        logger.info("ffmpeg is available (for fallback audio extraction)")
    except (subprocess.SubprocessError, FileNotFoundError):
        logger.warning("ffmpeg not found. Audio extraction will rely on yt-dlp only.")
    
    if not ASSEMBLYAI_API_KEY:
        logger.warning("AssemblyAI API key not found. Transcription will not work.")
    
    if not os.path.exists(SERVICE_ACCOUNT_FILE):
        logger.warning(f"Service account file not found at {SERVICE_ACCOUNT_FILE}. Google Docs integration will not work.")
    
    creds = get_google_credentials()
    if creds:
        logger.info("Google service account credentials loaded successfully")
    else:
        logger.error("Failed to load Google service account credentials")
    
    # Run immediately on startup
    check_for_new_entries()
    
    # Schedule checks every few hours (GMT times for MST = GMT-7)
    gmt_slots = ["16:00", "18:00", "20:00", "22:00", "00:00", "02:00"]

    for t in gmt_slots:
        schedule.every().day.at(t).do(check_for_new_entries)
    
    # Keep the script running
    while True:
        schedule.run_pending()
        time.sleep(60)


if __name__ == "__main__":
    main()
